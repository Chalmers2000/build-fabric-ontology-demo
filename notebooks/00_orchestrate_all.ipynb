 "cells": [
  {
   "cell_type": "markdown",
   "id": "db9d0f6a",
   "metadata": {},
   "source": [
    "# Healthcare Demo — Orchestrator\n",
    "Runs all five data-build notebooks in sequence. Each step is timed and logged. The run stops immediately if any notebook raises an exception."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1afa5c27",
   "metadata": {},
   "outputs": [],
   "source": [
   "from datetime import datetime\n"
   "from pyspark.sql.types import StructType, StructField, IntegerType, StringType\n",
   "\n",
   "# Configuration\n",
   "# TIMEOUT_SECONDS is applied to each referenced notebook.\n",
   "# All notebooks are expected to exist in the same workspace as this orchestrator.\n",
   "TIMEOUT_SECONDS = 1800\n",
    "\n",
    "NOTEBOOKS = [\n",
    "    \"01_create_provider_patient\",\n",
    "    \"02_create_appointment\",\n",
    "    \"03_create_diagnosis\",\n",
    "    \"04_create_prescription\",\n",
    "    \"05_validate_and_sample_queries\",\n",
    "]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "426fd044",
   "metadata": {},
   "outputs": [],
   "source": [
    "run_log = []\n",
    "orchestration_start = datetime.now()\n",
    "print(f\"Orchestration started at {orchestration_start.strftime('%Y-%m-%d %H:%M:%S')}\\n\")\n",
    "\n",
    "for step, nb_name in enumerate(NOTEBOOKS, start=1):\n",
    "    step_start = datetime.now()\n",
    "    status = \"RUNNING\"\n",
    "    print(f\"[{step}/{len(NOTEBOOKS)}] Starting: {nb_name} ...\")\n",
    "    try:\n",
    "        exit_value = notebookutils.notebook.run(nb_name, TIMEOUT_SECONDS, {})\n",
    "        elapsed = (datetime.now() - step_start).seconds\n",
    "        status = \"PASS\"\n",
    "        print(f\"  Completed in {elapsed}s\")\n",
    "        if exit_value not in [None, \"\"]:\n",
    "            print(f\"  Exit value: {exit_value}\")\n",
    "        print()\n",
    "    except Exception as ex:\n",
    "        elapsed = (datetime.now() - step_start).seconds\n",
    "        status = \"FAIL\"\n",
    "        run_log.append({\n",
    "            \"step\": step,\n",
    "            \"notebook\": nb_name,\n",
    "            \"status\": status,\n",
    "            \"elapsed_seconds\": elapsed,\n",
    "            \"error\": str(ex)\n",
    "        })\n",
    "        print(f\"  FAILED after {elapsed}s - stopping orchestration.\\n\")\n",
    "        print(f\"  Error: {ex}\\n\")\n",
    "        break\n",
    "\n",
     "    run_log.append({\n",
     "        \"step\": step,\n",
     "        \"notebook\": nb_name,\n",
     "        \"status\": status,\n",
     "        \"elapsed_seconds\": elapsed,\n",
     "        \"error\": \"\"\n",
    "    })\n",
    "\n",
    "total_elapsed = (datetime.now() - orchestration_start).seconds\n",
    "overall_status = \"PASS\" if run_log and all(r[\"status\"] == \"PASS\" for r in run_log) else \"FAIL\"\n",
    "print(f\"Orchestration {overall_status} - total {total_elapsed}s\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e8e8f080",
   "metadata": {},
   "outputs": [],
   "source": [
     "# Render the execution summary as a Spark table for easy reading in Fabric.\n",
     "summary_schema = StructType([\n",
     "    StructField(\"step\", IntegerType(), True),\n",
     "    StructField(\"notebook\", StringType(), True),\n",
     "    StructField(\"status\", StringType(), True),\n",
     "    StructField(\"elapsed_seconds\", IntegerType(), True),\n",
     "    StructField(\"error\", StringType(), True)\n",
     "])\n",
    "summary_df = spark.createDataFrame(run_log, schema=summary_schema)\n",
    "summary_df = summary_df.select(\"step\", \"notebook\", \"status\", \"elapsed_seconds\", \"error\")\n",
    "display(summary_df.orderBy(\"step\"))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d6fb8df4",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Raise at the end so a pipeline calling this notebook sees a clear failure signal.\n",
    "if overall_status == \"FAIL\":\n",
    "    failed = [r for r in run_log if r[\"status\"] == \"FAIL\"]\n",
    "    raise RuntimeError(\n",
    "        f\"{len(failed)} notebook(s) failed: {[f['notebook'] for f in failed]}\"\n",
    "    )\n",
    "print(\"All notebooks completed successfully.\")"
   ]
  }
 ],
